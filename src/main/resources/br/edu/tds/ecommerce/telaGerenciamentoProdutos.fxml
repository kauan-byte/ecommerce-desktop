<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.tds.ecommerce.TelaGerenciamentoProdutosController">
   <top>
      <HBox alignment="CENTER" prefHeight="98.0" prefWidth="700.0" style="-fx-background-color: red;" BorderPane.alignment="CENTER">
         <children>
            <Button mnemonicParsing="false" style="-fx-font-size: 20px; -fx-background-color: red;" text="Gerenciamento de Produtos">
               <font>
                  <Font name="System Bold" size="13.0" />
               </font>
            </Button>
         </children>
      </HBox>
   </top>
   <bottom>
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="20.0" BorderPane.alignment="CENTER">
         <children>
                       
            <Button mnemonicParsing="false" onAction="#abrirTelaCadastroUsuarioProduto" style="-fx-background-color: #248EFF;" text="+ Novo" />
            <Button mnemonicParsing="false" onAction="#editarProduto" style="-fx-background-color: yellow;" text="l Editar" />
            <Button mnemonicParsing="false" onAction="#excluirProduto" style="-fx-background-color: ff003b;" text="x Excluir" />
         </children>
      </HBox>
   </bottom>
   <center>
      <TableView fx:id="tabelaProdutos" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <columns>
          <TableColumn fx:id="colNome" prefWidth="161.0" text="Nome do Produto" />
          <TableColumn fx:id="colCategoria" prefWidth="171.0" text="Categoria" />
            <TableColumn fx:id="colPreco" prefWidth="108.0" text="Preço" />
            <TableColumn fx:id="colQuantidade" prefWidth="83.0" text="Quantidade" />
            <TableColumn fx:id="colAtivo" prefWidth="75.0" text="Ativo" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </center>
</BorderPane>
