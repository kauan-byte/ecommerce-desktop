<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane
    fx:id="painelPrincipal"
    prefHeight="900.0"
    prefWidth="1600.0"
    stylesheets="@css/dashboard.css"
    xmlns="http://javafx.com/javafx/25"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="br.edu.tds.ecommerce.DashboardController">

    <!-- SIDEBAR -->

    <left>

        <AnchorPane prefWidth="280.0" styleClass="sidebar">

            <children>

                <!-- LOGO -->

                <FontIcon
                    iconLiteral="fas-store"
                    iconColor="WHITE"
                    iconSize="75"
                    layoutX="95"
                    layoutY="100" />

                <Text
                    fill="WHITE"
                    layoutX="45"
                    layoutY="170"
                    text="Dashboard">

                    <font>
                        <Font size="30" />
                    </font>

                </Text>

                <!-- MENU -->

                <Button
                    layoutX="20"
                    layoutY="240"
                    prefWidth="230"
                    onAction="#abrirUsuarios"
                    styleClass="menu-button"
                    text="Usuários">

                    <graphic>
                        <FontIcon
                            iconLiteral="fas-users"
                            iconColor="WHITE"
                            iconSize="20" />
                    </graphic>

                </Button>

                <Button
                    layoutX="20"
                    layoutY="300"
                    prefWidth="230"
                    onAction="#abrirProdutos"
                    styleClass="menu-button"
                    text="Produtos">

                    <graphic>
                        <FontIcon
                            iconLiteral="fas-box-open"
                            iconColor="WHITE"
                            iconSize="20" />
                    </graphic>

                </Button>

                <Button
                    layoutX="20"
                    layoutY="360"
                    prefWidth="230"
                    onAction="#abrirFornecedores"
                    styleClass="menu-button"
                    text="Fornecedores">

                    <graphic>
                        <FontIcon
                            iconLiteral="fas-truck"
                            iconColor="WHITE"
                            iconSize="20" />
                    </graphic>

                </Button>

                <Button
                    layoutX="20"
                    layoutY="420"
                    prefWidth="230"
                    onAction="#abrirVendas"
                    styleClass="menu-button"
                    text="Vendas">

                    <graphic>
                        <FontIcon
                            iconLiteral="fas-shopping-cart"
                            iconColor="WHITE"
                            iconSize="20" />
                    </graphic>

                </Button>

                <Button
                    layoutX="20"
                    layoutY="480"
                    prefWidth="230"
                    onAction="#abrirFinanceiro"
                    styleClass="menu-button"
                    text="Financeiro">

                    <graphic>
                        <FontIcon
                            iconLiteral="fas-dollar-sign"
                            iconColor="WHITE"
                            iconSize="20" />
                    </graphic>

                </Button>

                <Button
                    layoutX="20"
                    layoutY="540"
                    prefWidth="230"
                    onAction="#abrirRelatorios"
                    styleClass="menu-button"
                    text="Relatórios">

                    <graphic>
                        <FontIcon
                            iconLiteral="fas-chart-line"
                            iconColor="WHITE"
                            iconSize="20" />
                    </graphic>

                </Button>

                <!-- BOTÃO LOGOUT -->

                <Button
                    layoutX="40"
                    layoutY="780"
                    prefWidth="190"
                    onAction="#logout"
                    styleClass="logout-button"
                    text="Logout">

                    <graphic>

                        <FontIcon
                            iconLiteral="fas-sign-out-alt"
                            iconColor="WHITE"
                            iconSize="20" />

                    </graphic>

                </Button>

            </children>

        </AnchorPane>

    </left>

      <!-- ===================================================== -->
    <!-- ÁREA CENTRAL -->
    <!-- ===================================================== -->

    <center>

        <AnchorPane styleClass="dashboard-background">

            <children>

                <!-- ===================================================== -->
                <!-- CARD USUÁRIOS -->
                <!-- ===================================================== -->

                <AnchorPane
                    layoutX="40"
                    layoutY="40"
                    prefWidth="360"
                    prefHeight="300"
                    styleClass="card"
                    onMouseClicked="#abrirUsuarios">

                    <children>

                        <FontIcon
                            iconLiteral="fas-users"
                            iconColor="#0598ff"
                            iconSize="90"
                            layoutX="135"
                            layoutY="110" />

                        <Text
                            layoutX="95"
                            layoutY="190"
                            styleClass="card-title"
                            text="Usuários" />

                        <Text
                            layoutX="50"
                            layoutY="230"
                            styleClass="card-subtitle"
                            text="Gerencie usuários do sistema" />

                    </children>

                </AnchorPane>

                <!-- ===================================================== -->
                <!-- CARD PRODUTOS -->
                <!-- ===================================================== -->

                <AnchorPane
                    layoutX="430"
                    layoutY="40"
                    prefWidth="360"
                    prefHeight="300"
                    styleClass="card"
                    onMouseClicked="#abrirProdutos">

                    <children>

                        <FontIcon
                            iconLiteral="fas-box-open"
                            iconColor="#0598ff"
                            iconSize="90"
                            layoutX="135"
                            layoutY="110" />

                        <Text
                            layoutX="95"
                            layoutY="190"
                            styleClass="card-title"
                            text="Produtos" />

                        <Text
                            layoutX="55"
                            layoutY="230"
                            styleClass="card-subtitle"
                            text="Controle de estoque e catálogo" />

                    </children>

                </AnchorPane>

                <!-- ===================================================== -->
                <!-- CARD FORNECEDORES -->
                <!-- ===================================================== -->

                <AnchorPane
                    layoutX="820"
                    layoutY="40"
                    prefWidth="360"
                    prefHeight="300"
                    styleClass="card"
                    onMouseClicked="#abrirFornecedores">

                    <children>

                        <FontIcon
                            iconLiteral="fas-truck"
                            iconColor="#0598ff"
                            iconSize="90"
                            layoutX="135"
                            layoutY="110" />

                        <Text
                            layoutX="55"
                            layoutY="190"
                            styleClass="card-title"
                            text="Fornecedores" />

                        <Text
                            layoutX="55"
                            layoutY="230"
                            styleClass="card-subtitle"
                            text="Controle de fornecedores" />

                    </children>

                </AnchorPane>

                <!-- ===================================================== -->
                <!-- CARD VENDAS -->
                <!-- ===================================================== -->

                <AnchorPane
                    layoutX="40"
                    layoutY="390"
                    prefWidth="360"
                    prefHeight="300"
                    styleClass="card"
                    onMouseClicked="#abrirVendas">

                    <children>

                        <FontIcon
                            iconLiteral="fas-shopping-cart"
                            iconColor="#0598ff"
                            iconSize="90"
                            layoutX="125"
                            layoutY="110" />

                        <Text
                            layoutX="115"
                            layoutY="190"
                            styleClass="card-title"
                            text="Vendas" />

                        <Text
                            layoutX="60"
                            layoutY="230"
                            styleClass="card-subtitle"
                            text="Gerenciamento de vendas" />

                    </children>

                </AnchorPane>

                <!-- ===================================================== -->
                <!-- CARD FINANCEIRO -->
                <!-- ===================================================== -->

                <AnchorPane
                    layoutX="430"
                    layoutY="390"
                    prefWidth="360"
                    prefHeight="300"
                    styleClass="card"
                    onMouseClicked="#abrirFinanceiro">

                    <children>

                        <FontIcon
                            iconLiteral="fas-dollar-sign"
                            iconColor="#0598ff"
                            iconSize="90"
                            layoutX="145"
                            layoutY="110" />

                        <Text
                            layoutX="85"
                            layoutY="190"
                            styleClass="card-title"
                            text="Financeiro" />

                        <Text
                            layoutX="55"
                            layoutY="230"
                            styleClass="card-subtitle"
                            text="Controle financeiro geral" />

                    </children>

                </AnchorPane>

                <!-- ===================================================== -->
                <!-- CARD RELATÓRIOS -->
                <!-- ===================================================== -->

                <AnchorPane
                    layoutX="820"
                    layoutY="390"
                    prefWidth="360"
                    prefHeight="300"
                    styleClass="card"
                    onMouseClicked="#abrirRelatorios">

                    <children>

                        <FontIcon
                            iconLiteral="fas-chart-line"
                            iconColor="#0598ff"
                            iconSize="90"
                            layoutX="135"
                            layoutY="110" />

                        <Text
                            layoutX="70"
                            layoutY="190"
                            styleClass="card-title"
                            text="Relatórios" />

                        <Text
                            layoutX="50"
                            layoutY="230"
                            styleClass="card-subtitle"
                            text="Estatísticas e relatórios" />

                    </children>

                </AnchorPane>

            </children>

        </AnchorPane>

    </center>

</BorderPane>