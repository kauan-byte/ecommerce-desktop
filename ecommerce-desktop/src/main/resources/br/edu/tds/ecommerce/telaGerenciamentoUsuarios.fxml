<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://dependency.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.tds.ecommerce.TelaGerenciamentoUsuariosController">
   <top>
      <HBox alignment="CENTER" prefHeight="98.0" prefWidth="630.0" style="-fx-background-color: red;" BorderPane.alignment="CENTER">
         <children>
            <Button mnemonicParsing="false" style="-fx-font-size: 20px; -fx-background-color: red;" text="Gerenciamento de Usuarios">
               <font>
                  <Font name="System Bold" size="13.0" />
               </font>
            </Button>
         </children>
      </HBox>
   </top>
   <bottom>
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="20.0" BorderPane.alignment="CENTER">
         <children>
                       
            <Button mnemonicParsing="false" onAction="#abrirTelaCadastroUsuario" style="-fx-background-color: #248EFF;" text="+ Novo" />
            <Button mnemonicParsing="false" onAction="#editarUsuario" style="-fx-background-color: yellow;" text="l Editar" />
            <Button mnemonicParsing="false" onAction="#excluirUsuario" style="-fx-background-color: ff003b;" text="x Excluir" />
         </children>
      </HBox>
   </bottom>
   <center>
      <TableView fx:id="tabelaUsuarios" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <columns>
          <TableColumn fx:id="colNomeCompleto" prefWidth="120.0" text="Nome Completo" />
          <TableColumn fx:id="colUsuario" prefWidth="133.0" text="Usuario" />
            <TableColumn fx:id="colEmail" prefWidth="158.0" text="E-mail" />
            <TableColumn fx:id="colCPF" prefWidth="160.0" text="CPF" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </center>
</BorderPane>
